# Copy these into Railway's "Variables" tab for the service (not into a
# committed .env file). Only vars the code actually reads are listed here.

# Required — without a fixed secret, every redeploy/restart invalidates all
# logged-in sessions because main.py falls back to a random one-shot value.
# Generate with: python3 -c "import secrets; print(secrets.token_hex(32))"
SESSION_SECRET=change-this-to-a-random-64-char-hex-string

# Required if you attach a Railway Volume (strongly recommended — see below).
# Point this at the volume's mount path so the SQLite DB and every user's
# uploaded server files survive redeploys and restarts.
DATA_DIR=/data

# Optional — lock Socket.IO CORS to your real domain once Railway assigns
# one (Settings -> Networking -> Generate Domain). Comma-separate multiple.
# Leave unset ("*") until you know the domain, then tighten it.
CORS_ORIGINS=https://your-app-name.up.railway.app

# RAILWAY_ENVIRONMENT is set automatically by Railway itself — do not set
# this manually. main.py uses its presence to turn on Secure session cookies.
